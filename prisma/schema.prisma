generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Service {
  id              String    @id @default(cuid())
  slug            String    @unique
  iconKey         String
  iconColor       String
  iconBg          String
  title           String
  description     String
  fullDescription String
  price           Int
  specialists     String
  scheduleHours   String
  scheduleNote    String
  image           String?
  bookings        Booking[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Doctor {
  id            String  @id @default(cuid())
  name          String
  role          String
  qualification String
  schedule      String
  avatarUrl     String?
  active        Boolean @default(true)
}

model Review {
  id              String @id @default(cuid())
  doctorName      String
  doctorRole      String
  doctorAvatarUrl String
  text            String
  authorName      String
  rating          Int
}

model Contact {
  id      String @id @default("main")
  address String
  phone   String
  email   String
}

model Program {
  id          String  @id @default(cuid())
  title       String
  description String
  price       Int?
  active      Boolean @default(true)
}

model Booking {
  id           String   @id @default(cuid())
  serviceId    String
  serviceTitle String
  patientName  String
  phone        String
  date         String
  createdAt    DateTime @default(now())
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}
